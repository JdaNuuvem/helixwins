# ─── Servidor ────────────────────────────────────────────────────────────────
# Porta (Coolify injeta automaticamente, não precisa configurar lá)
PORT=3000
NODE_ENV=production

# ─── Segurança ───────────────────────────────────────────────────────────────
# OBRIGATÓRIO: substitua por uma chave aleatória forte (mínimo 32 chars)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Origens permitidas (seu domínio). Separar por vírgula se tiver mais de um.
ALLOWED_ORIGINS=https://seudominio.com

# ─── AmploPay Gateway ────────────────────────────────────────────────────────
# Obtenha em: https://app.amplopay.com (menu Integrações > API)
AMPLOPAY_PUBLIC_KEY=
AMPLOPAY_SECRET_KEY=

# OBRIGATÓRIO: Token do webhook (gerado ao configurar webhook no painel AmploPay)
AMPLOPAY_WEBHOOK_TOKEN=

# URL pública do seu servidor (para callbacks e links de indicação)
WEBHOOK_BASE_URL=https://seudominio.com
