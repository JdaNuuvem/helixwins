# ═══════════════════════════════════════════════════════════════════════════
# HELIXWINS — Configuração de Produção
# ═══════════════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o .env real (já está no .gitignore).
# ═══════════════════════════════════════════════════════════════════════════

# ─── AMBIENTE (OBRIGATÓRIO) ─────────────────────────────────────────────────
# "production" ativa: cookies secure, HSTS header, fail-closed em SP/JWT
NODE_ENV=production

# Porta do servidor (atrás do reverse proxy)
PORT=8888

# URL pública HTTPS — usada nos webhooks que o gateway chama
# IMPORTANTE: deve bater com o domínio configurado no gateway
WEBHOOK_BASE_URL=https://seu-dominio.com.br

# Origens permitidas para CORS — separadas por vírgula
ALLOWED_ORIGINS=https://seu-dominio.com.br

# Pasta onde fica o database.json — deve ser volume persistente
DATA_DIR=/data


# ─── SEGURANÇA / AUTH (OBRIGATÓRIO EM PRODUÇÃO) ─────────────────────────────
# JWT_SECRET — chave de assinatura dos tokens. Em produção sem isso, o server
# falha no boot. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cole_aqui_64_chars_hexadecimais_gerados_pelo_comando_acima

# Credenciais do /ctrl-sp (configuração do split do gateway)
# Se não definidas em produção, server falha no boot.
SP_USER=seu_usuario_admin_split
SP_PASS=senha_complexa_minimo_24_caracteres_aqui


# ─── GATEWAY: ParadisePags (ATIVO) ──────────────────────────────────────────
# Pegue a Secret Key no painel da ParadisePags
PARADISEPAGS_SECRET_KEY=sk_sua_secret_key_da_paradisepags

# URL base da API (padrão)
PARADISEPAGS_BASE_URL=https://multi.paradisepags.com

# webhook_secret é configurado via UI no painel do super admin > Gateway,
# OU diretamente no banco em db.gateway_config.paradisepags.webhook_secret
# Esse mesmo valor deve estar no painel da ParadisePags em:
#   "Webhook URL: https://seu-dominio.com.br/api/webhooks/paradisepags"
#   "Webhook Secret: <mesmo valor do DB>"


# ─── GATEWAY: AmploPay (DESABILITADO — em desenvolvimento) ──────────────────
# Mantido por compatibilidade. Não é usado no fluxo atual.
AMPLOPAY_PUBLIC_KEY=
AMPLOPAY_SECRET_KEY=
AMPLOPAY_WEBHOOK_TOKEN=


# ─── SPLIT (OPCIONAL — só se for usar split de gateway) ─────────────────────
# Chave secreta da conta destino (PJ separada) para onde 1 a cada N pagamentos
# será redirecionado. Configurável também em /ctrl-sp.
SPLIT_SK=


# ─── SEED ADMIN (OPCIONAL — cria admin no primeiro boot) ────────────────────
# Se definido, cria automaticamente um user com admin=1 (vira super_admin
# pela migração) no primeiro boot. Útil para Coolify/Docker.
# Após o primeiro boot, pode remover essas variáveis (o user já está no DB).
ADMIN1_TEL=21999999999
ADMIN1_NOME=Seu Nome Completo
ADMIN1_EMAIL=voce@email.com
ADMIN1_SENHA=SuaSenhaForte!2026
ADMIN1_CPF=12345678901


# ═══════════════════════════════════════════════════════════════════════════
# CHECKLIST PRÉ-DEPLOY
# ═══════════════════════════════════════════════════════════════════════════
# [ ] NODE_ENV=production
# [ ] JWT_SECRET com 64 hex chars
# [ ] SP_USER e SP_PASS preenchidos
# [ ] WEBHOOK_BASE_URL com HTTPS
# [ ] ALLOWED_ORIGINS apontando pro mesmo domínio
# [ ] PARADISEPAGS_SECRET_KEY válida
# [ ] DATA_DIR em volume persistente
# [ ] webhook_secret configurado via UI após primeiro deploy
# [ ] Admin criado (via ADMIN1_* OU manual)
# [ ] Reverse proxy HTTPS na frente do server
# [ ] Backup automático do database.json configurado
# ═══════════════════════════════════════════════════════════════════════════
