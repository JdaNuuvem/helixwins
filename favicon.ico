<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HelixWin — Gire e Ganhe</title>
  <meta name="description" content="Jogue Helix Jump e transforme suas habilidades em dinheiro real." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <!-- Loading global -->
  <div id="global-loading" class="global-loading hidden">
    <div class="loading-spinner"></div>
  </div>

  <!-- Toast container -->
  <div id="toast-container" class="toast-container"></div>

  <div id="app">
    <section id="page-landing"  class="page"></section>
    <section id="page-login"    class="page"></section>
    <section id="page-cadastro" class="page"></section>
    <section id="page-painel"   class="page"></section>
    <section id="page-jogo"     class="page"></section>
  </div>

  <!-- Utilitários antes de tudo -->
  <script src="/js/utils.js"></script>
  <script src="/js/api.js"></script>

  <!-- Páginas -->
  <script src="/js/pages/landing.js"></script>
  <script src="/js/pages/login.js"></script>
  <script src="/js/pages/cadastro.js"></script>
  <script src="/js/pages/painel.js"></script>
  <script src="/js/pages/jogo.js"></script>

  <!-- Router — carregado por último -->
  <script src="/js/app.js"></script>
</body>
</html>
